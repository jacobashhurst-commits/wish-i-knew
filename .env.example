NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_publishable_or_anon_key
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000

# Soft launch (production defaults to auth required + invite-only)
WIK_REQUIRE_AUTH=false
WIK_BETA_INVITE_ONLY=true

# Server-only. Required for the weekly lookahead email cron.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
RESEND_API_KEY=your_resend_api_key
WIK_FROM_EMAIL="Wish I Knew <hello@yourdomain.com>"
CRON_SECRET=any_long_random_string
